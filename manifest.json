{
  "manifest_version": 3,
  "name": "Forever Tabs",
  "version": "1.0",
  "description": "Always open specified websites as pinned tabs in every new window.",
  "browser_specific_settings": {
    "gecko": {
      "id": "forever-tabs@example.com",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  },
  "permissions": [
    "tabs",
    "storage"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "action": {
    "default_icon": "icons/icon.svg",
    "default_title": "Forever Tabs Settings"
  },
  "icons": {
    "48": "icons/icon.svg",
    "96": "icons/icon.svg"
  }
}
